<svg width="1200" height="630" xmlns="http://www.w3.org/2000/svg">
  <rect width="1200" height="630" fill="#0a0e1a"/>
  <rect x="0" y="0" width="1200" height="630" fill="url(#grid)" opacity="0.3"/>
  <defs>
    <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
      <path d="M 60 0 L 0 0 0 60" fill="none" stroke="rgba(56,189,248,0.05)" stroke-width="1"/>
    </pattern>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#38bdf8"/>
      <stop offset="100%" style="stop-color:#818cf8"/>
    </linearGradient>
  </defs>
  <text x="600" y="240" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="72" font-weight="800" fill="#f1f5f9">DadStocks</text>
  <text x="600" y="320" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="32" fill="#94a3b8">Your daily stock briefing, personalized</text>
  <rect x="420" y="370" width="360" height="50" rx="12" fill="url(#accent)"/>
  <text x="600" y="403" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="18" font-weight="600" fill="#fff">Get your free briefing</text>
  <text x="600" y="560" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="16" fill="#64748b">Built by Redwood Digital</text>
</svg>
